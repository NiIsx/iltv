|  |  |── …/
|  |── some_2/
|  |  |── some_2_domain.dart
|  |  └──  …/
|── procedures/
|  |── main_procedures.dart //Important
|  |── some_1/
|  |  |── some_1_procedures.dart
|  |  |── …/
|  |── some_2/
|  |  |── some_2_procedures.dart
|  |  └──  …/
|── repositories/
|  |── some_1/
|  |  |── some_1_repository.dart
|  |  |── …/
